# Model weights / checkpoints
# =========================
model/
*.pth
*.pt
*.ckpt


# =========================
# Generated training results
# =========================
picture/training_results/*
!picture/training_results/.gitkeep
picture/sample_*.png
picture/*prediction*.png
picture/run_info.txt


# =========================
