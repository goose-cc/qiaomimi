# =========================
# Python cache
# =========================
__pycache__/
*/__pycache__/
*.py[cod]
*$py.class


# =========================
# Virtual environment
# =========================
venv/
.venv/
env/
ENV/


# =========================
# IDE / editor
# =========================
.vscode/
.idea/


# =========================
# OS files
# =========================
.DS_Store
Thumbs.db


# =========================
# Old single-sample dataset folders
